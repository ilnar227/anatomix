# Server
PORT=3000
NODE_ENV=development

# Database — use either DATABASE_URL (Render / production) or the discrete vars (local).
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/weather_ai

# Optional: only used when DATABASE_URL is unset
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=weather_ai

# Auth
JWT_SECRET=replace_with_a_long_random_string

# Frontend origin for CORS (comma-separated for multiple). Omit or use * for allow-all (dev only).
CORS_ORIGIN=http://localhost:5173

# Optional: used if you add weather/AI routes later
WEATHER_API_KEY=
AI_API_KEY=
